# Dependencies
node_modules/

# Build outputs (regenerate: npm run build / dist:win)
dist/
dist-electron/
release/
release-*/
out/
build/
*.asar

# Installers / OS packages (regenerate via electron-builder)
*.exe
*.msi
*.dmg
*.AppImage
*.deb
*.rpm

# Archives produced locally (keep release zips out of git)
*.zip
*.7z

# Tooling caches
.vite/
.turbo/
.cache/
.eslintcache
node_modules/.cache/

# Test and coverage artifacts
coverage/
.nyc_output/
test-results/
playwright-report/
playwright-results.json
blob-report/
e2e/artifacts/

# Local databases, backups, and runtime data
.data/
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.sqlite-shm
*.sqlite-wal
backups/
backup/
*.backup

# Logs and diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
diagnostic-bundles/

# Cleanup quarantine (local only; review then delete manually)
_quarantine/

# Local secrets
.env
.env.*
!.env.example
!.env.template

# OS and editor
.DS_Store
Thumbs.db
Desktop.ini
*.tmp
*.temp
*.swp
*.swo
~$*

# Prisma local DB files (schema + migrations stay tracked)
prisma/*.db
prisma/*.sqlite
prisma/dev.db*

# Explicit keeps (documentation)
!docs/
!docs/**/*
!prisma/migrations/
!prisma/migrations/**/*
