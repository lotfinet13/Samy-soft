{
  "name": "samy-soft",
  "version": "0.2.0",
  "private": true,
  "description": "SAMY SOFT — ERP industriel local-first pour glacerie (Algérie)",
  "author": "SAMY SOFT",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:electron && vite build && prisma generate",
    "build:electron": "tsc -p electron/tsconfig.json && npm run build:preload",
    "build:preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --target=node20 --external:electron --outfile=dist-electron/electron/preload.cjs",
    "preview": "vite preview",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit && tsc -p electron/tsconfig.preload.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "verify:desktop": "npm run lint && npm run build && npx prisma validate",
    "test:unit": "vitest run",
    "playwright:install": "playwright install",
    "e2e:db:push": "cross-env DATABASE_URL=file:../.data/e2e/samye2e.sqlite prisma db push --accept-data-loss --skip-generate",
    "e2e:seed": "cross-env DATABASE_URL=file:../.data/e2e/samye2e.sqlite SAMY_SEED_SKIP_WIZARD=1 SAMY_E2E=1 SAMY_SEED_ADMIN_PASSWORD=E2E_Admin_Stable_12! prisma db seed",
    "e2e:fixtures": "cross-env DATABASE_URL=file:../.data/e2e/samye2e.sqlite tsx prisma/e2e-fixtures.ts",
    "e2e:ensure-db": "npm run e2e:db:push && npm run e2e:seed && npm run e2e:fixtures",
    "e2e:prepare": "npm run build:electron && vite build && npm run e2e:ensure-db",
    "e2e": "npm run e2e:ensure-db && cross-env SAMY_E2E=1 SAMY_SKIP_DEVTOOLS=1 SAMY_E2E_DATABASE_PATH=.data/e2e/samye2e.sqlite playwright test",
    "qa:certs-installer": "tsx scripts/check-installer-artifacts.ts",
    "qa:perf-sample": "tsx scripts/performance-sample.ts",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.3.1",
    "@tanstack/react-table": "^8.20.6",
    "@tanstack/react-virtual": "^3.13.24",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "postcss": "^8.4.49",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.6",
    "wait-on": "^8.0.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "build": {
    "appId": "dz.samysoft.desktop",
    "productName": "SAMY SOFT",
    "copyright": "Copyright © SAMY SOFT — usage site industriel fermé.",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/@prisma/client/**/*",
      "**/node_modules/.prisma/**/*"
    ],
    "win": {
      "publisherName": "SAMY SOFT",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "installerLanguages": [
        "fr_FR"
      ]
    }
  }
}
